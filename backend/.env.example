# OpenAI
# Copy these lines into backend/.env and replace the key with a newly generated one.
OPENAI_API_KEY=replace_with_new_openai_api_key

# Model defaults
# GPT-5 mini is a cheaper default for this student chat + analysis flow.
# If you want the newer recommended mini model, use gpt-5.4-mini instead.
OPENAI_MODEL_GENERAL=gpt-5-mini
OPENAI_MODEL_CHAT=gpt-5-mini
OPENAI_MODEL_ANALYSIS=gpt-5-mini
OPENAI_MODEL_SUMMARY=gpt-5-mini
OPENAI_MODEL_PARSER=gpt-5-mini
OPENAI_MODEL_QUESTION_GENERATION=gpt-5-mini
