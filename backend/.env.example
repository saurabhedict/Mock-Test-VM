# Gemini
# Get a free Gemini API key from Google AI Studio, then paste it into backend/.env.
GEMINI_API_KEY=replace_with_gemini_api_key

# Model defaults
# Gemini 2.5 Flash-Lite currently has structured output support and a free tier.
GEMINI_MODEL_GENERAL=gemini-2.5-flash-lite
GEMINI_MODEL_CHAT=gemini-2.5-flash-lite
GEMINI_MODEL_ANALYSIS=gemini-2.5-flash-lite
GEMINI_MODEL_SUMMARY=gemini-2.5-flash-lite
GEMINI_MODEL_PARSER=gemini-2.5-flash-lite
GEMINI_MODEL_QUESTION_GENERATION=gemini-2.5-flash-lite
